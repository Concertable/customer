{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Concertable": "Information",
      "Microsoft.EntityFrameworkCore": "Error",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "ExternalServices": {
    "UseRealStripe": true,
    "UseRealBlob": true,
    "UseRealEmail": false
